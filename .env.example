# Generic source discovery (existing API)
SOURCE_SITE=https://example-source.com/
FALLBACK_DIARIES_URL=https://example-source.com/diaries.json
SCRAPE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_WITH_YOURS

# Feed scraper target configuration (required for scrape:feed* scripts)
FEED_BASE_URL=https://example-feed-source.com
FEED_HOME_PATH=/
FEED_EVENT_PATH_SEGMENT=/eventinfo/

# Optional: custom host regex used when TLS fallback retry is needed
# FEED_INSECURE_HOST_REGEX=example-feed-source\.com|mirror\d+\.example-feed-source\.com

# Existing scraper controls
FEED_INSECURE_TLS=0
FEED_TOP_MAX=10
FEED_DAYS_MAX=
FEED_DAYS_WINDOW=2
FEED_MAX_EVENTS=

# Fallback values for /api/events live-source payload mapping
LIVE_EVENTS_SOURCE_FALLBACK=https://example-feed-source.com/
LIVE_EVENTS_DIARIES_FALLBACK=https://example-feed-source.com/events/
